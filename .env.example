# ═══════════════════════════════════════════════
# Подряд PRO — Environment Variables
# ═══════════════════════════════════════════════
# Скопируй в .env.local (для Next.js) или .env (для Docker)

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHANNEL_ID=YOUR_CHANNEL_ID
TELEGRAM_ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID

# ── MAX Messenger ─────────────────────────────
MAX_BOT_TOKEN=YOUR_MAX_BOT_TOKEN
MAX_CHANNEL_ID=YOUR_MAX_CHANNEL_CHAT_ID
MAX_API_BASE=https://platform-api.max.ru
NEXT_PUBLIC_MAX_CHANNEL_LINK=https://max.ru/YOUR_CHANNEL_NAME
NEXT_PUBLIC_MAX_BOT_NAME=PodraydPRO_bot

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_KEY

# ── Google Sheets ─────────────────────────────
GOOGLE_SHEETS_ID=1gEHLlSNMQIIxieDdHjrvqE15_AkoJIeuWKLRajZlOCk
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_SERVICE_ACCOUNT_EMAIL=YOUR_SERVICE_ACCOUNT
GOOGLE_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ── n8n ───────────────────────────────────────
N8N_WEBHOOK_BASE=https://YOUR_N8N_DOMAIN/webhook
N8N_DOMAIN=n8n.podryad.pro
N8N_ENCRYPTION_KEY=YOUR_RANDOM_ENCRYPTION_KEY
# Для owner-аккаунта n8n (первый запуск)
N8N_DEFAULT_USER_EMAIL=admin@podryad.pro
N8N_DEFAULT_USER_PASSWORD=YOUR_SECURE_PASSWORD

# ── ЮKassa ────────────────────────────────────
YUKASSA_SHOP_ID=YOUR_SHOP_ID
YUKASSA_SECRET_KEY=YOUR_SECRET_KEY

# ── App ───────────────────────────────────────
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
NEXT_PUBLIC_SITE_URL=https://podryad.pro
# Для подписи сессии (личный кабинет). Если пусто — используется TELEGRAM_BOT_TOKEN
SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET
