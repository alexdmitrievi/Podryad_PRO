# ═══════════════════════════════════════════════
# Подряд PRO — Environment Variables
# ═══════════════════════════════════════════════
# Скопируй в .env.local (для Next.js) или .env (для Docker)

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHANNEL_ID=YOUR_CHANNEL_ID
TELEGRAM_ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID
TELEGRAM_ADMIN_CHAT_ID=YOUR_ADMIN_TELEGRAM_CHAT_ID

# ── MAX Messenger ─────────────────────────────
MAX_BOT_TOKEN=YOUR_MAX_BOT_TOKEN
MAX_CHANNEL_ID=YOUR_MAX_CHANNEL_CHAT_ID
MAX_API_BASE=https://platform-api.max.ru
MAX_ADMIN_USER_ID=YOUR_MAX_ADMIN_USER_ID
NEXT_PUBLIC_MAX_CHANNEL_LINK=https://max.ru/YOUR_CHANNEL_NAME
NEXT_PUBLIC_MAX_BOT_NAME=PodraydPRO_bot

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_KEY

# ── Supabase (PostgreSQL) ─────────────────────
# URL и anon — с NEXT_PUBLIC_ (клиент + anon-клиент).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Только сервер (API routes, service role, обход RLS). Без NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Для GitHub Actions / cron (scripts/run_status_update.py) — тот же URL без NEXT_PUBLIC_:
#   SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Секреты в репозитории: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY

# ── n8n ───────────────────────────────────────
N8N_WEBHOOK_BASE=https://YOUR_N8N_DOMAIN/webhook
N8N_DOMAIN=n8n.podryad.pro
N8N_ENCRYPTION_KEY=YOUR_RANDOM_ENCRYPTION_KEY
# Для owner-аккаунта n8n (первый запуск)
N8N_DEFAULT_USER_EMAIL=admin@podryad.pro
N8N_DEFAULT_USER_PASSWORD=YOUR_SECURE_PASSWORD

# ── n8n Webhook URLs (используются в API routes) ──
N8N_LEADS_WEBHOOK_URL=
N8N_ORDER_CREATED_WEBHOOK_URL=
N8N_PAYOUT_WEBHOOK_URL=
N8N_PAYMENT_HELD_WEBHOOK_URL=
N8N_SEND_PAYMENT_LINK_WEBHOOK_URL=
N8N_SEND_INVOICE_WEBHOOK_URL=
N8N_SEND_DASHBOARD_LINK_WEBHOOK_URL=
N8N_CONTRACTOR_REGISTERED_WEBHOOK_URL=
# CRM: нотификация о новом лиде в воронку (WF-18)
N8N_CRM_LEAD_NURTURE_WEBHOOK_URL=
N8N_CRM_CONVERSION_WEBHOOK_URL=
N8N_CRM_PROSPECT_WEBHOOK_URL=
# Отклик исполнителя на заказ (WF-14 / custom)
N8N_EXECUTOR_RESPONSE_WEBHOOK_URL=
N8N_DISPUTE_OPENED_WEBHOOK_URL=
N8N_DISPUTE_RESOLVED_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# ── ЮKassa (УСТАРЕЛО — платёжная система удалена в апреле 2026) ──
# Оставлено для справки. Удалите, если не нужны.
# YUKASSA_SHOP_ID=YOUR_SHOP_ID
# YUKASSA_SECRET_KEY=YOUR_SECRET_KEY

# ── Admin (ручное добавление пользователей) ───
ADMIN_PIN=YOUR_ADMIN_PIN

# ── PWA Push Notifications ──────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@podryad.pro
PUSH_API_SECRET=random-secret-for-n8n-to-send-pushes

# ── Тендеры (Python FastAPI) ──────────────────
# URL Python API (uvicorn api.main:app) для страницы /tenders в PWA
NEXT_PUBLIC_TENDER_API_URL=https://your-tender-api.example.com

# ── App ───────────────────────────────────────
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
NEXT_PUBLIC_SITE_URL=https://podryad.pro
# Для подписи сессии (личный кабинет). Если пусто — используется TELEGRAM_BOT_TOKEN
SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET
