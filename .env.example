# ═══════════════════════════════════════════════
# Подряд PRO — Environment Variables
# ═══════════════════════════════════════════════
# Скопируйте в .env (для Docker/VPS) и заполните реальными значениями.
# Для Next.js PWA — скопируйте нужные переменные в podryad-pro/.env.local

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHANNEL_ID=YOUR_CHANNEL_ID
TELEGRAM_ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID

# --- OpenAI ---
OPENAI_API_KEY=YOUR_OPENAI_KEY

# --- Google Sheets ---
GOOGLE_SHEETS_ID=YOUR_SHEETS_ID
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_SERVICE_ACCOUNT_EMAIL=YOUR_SERVICE_ACCOUNT@YOUR_PROJECT.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# --- n8n ---
N8N_WEBHOOK_BASE=https://YOUR_N8N_DOMAIN/webhook
N8N_DOMAIN=n8n.podryad.pro

# --- ЮKassa ---
YUKASSA_SHOP_ID=YOUR_SHOP_ID
YUKASSA_SECRET_KEY=YOUR_SECRET_KEY

# --- Next.js (public) ---
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
