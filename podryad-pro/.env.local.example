# Подряд PRO — Next.js Environment Variables
# Скопируйте в .env.local и заполните реальными значениями

# Google Sheets (только чтение через API Key)
GOOGLE_SHEETS_ID=YOUR_SHEETS_ID
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# n8n Webhook (для отправки заказов из PWA)
N8N_WEBHOOK_BASE=https://YOUR_N8N_DOMAIN/webhook

# Public (доступны в клиентском коде)
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
