# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Session / Auth ──
SESSION_SECRET=generate-random-64-char-string
CUSTOMER_JWT_SECRET=generate-random-64-char-string
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── Admin PIN ──
ADMIN_PIN=your_admin_pin

# ── App URL ──
NEXT_PUBLIC_APP_URL=https://podryad.pro

# ── Telegram / Notifications ──
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
NEXT_PUBLIC_MAX_CHANNEL_LINK=https://max.ru/podryad_pro

# ── Cron webhook security ──
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-random-32-char-string

# ── n8n Webhooks ──
# Lead notifications (new orders, catalog orders, responses)
N8N_LEADS_WEBHOOK_URL=
# Webhook when a new order is created via /api/orders
N8N_ORDER_CREATED_WEBHOOK_URL=
# Webhook for manual payout notifications (manual_transfer + cash methods)
N8N_PAYOUT_WEBHOOK_URL=
# Send payment link to customer
N8N_SEND_PAYMENT_LINK_WEBHOOK_URL=
# Send dashboard link to customer after phone recovery
N8N_SEND_DASHBOARD_LINK_WEBHOOK_URL=
# Webhook when a new contractor registers
N8N_CONTRACTOR_REGISTERED_WEBHOOK_URL=
# Webhook for payment held notification (escrow hold confirmed)
N8N_PAYMENT_HELD_WEBHOOK_URL=
# CRM: lead nurture sequence trigger
N8N_CRM_LEAD_NURTURE_WEBHOOK_URL=
# CRM: conversion event tracker
N8N_CRM_CONVERSION_WEBHOOK_URL=
# CRM: prospect added (Avito)
N8N_CRM_PROSPECT_WEBHOOK_URL=
# Executor response notifications (admin gets notified of new bids)
N8N_EXECUTOR_RESPONSE_WEBHOOK_URL=
# Invoice sent to customer
N8N_SEND_INVOICE_WEBHOOK_URL=

# ── OpenAI GPT-4o (LLM for CRM Agent) ──
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_TIMEOUT=30000

# ── Channel Transport ──
# Telegram (already above in TELEGRAM_BOT_TOKEN)
# MAX Messenger
MAX_BOT_TOKEN=your_max_bot_access_token
# Avito Messenger — uses single API token (not OAuth client_id/secret)
AVITO_API_TOKEN=your_avito_api_token
# CRM: shared secret for /api/crm/update-stage
CRM_WEBHOOK_SECRET=generate-random-32-char-string

# ── Company details (for document generation: invoices, acts, UPD) ──
COMPANY_NAME=ИП Подряд ПРО
COMPANY_INN=your_inn
COMPANY_ADDRESS=your_legal_address
COMPANY_BANK=your_bank_name
COMPANY_BIK=your_bik
COMPANY_ACCOUNT=your_account_number
COMPANY_CORR_ACCOUNT=your_corr_account

# ── Push Notifications (Web Push / VAPID) ──
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@podryad.pro

# ── SMTP (Email channel for CRM agents) ──
# Configure SMTP credentials in n8n UI:
#   Settings → Credentials → Add → SMTP
#   Name: "Podryad PRO SMTP"
# The workflows 18 and 19 reference this credential by name.
# Supported providers: Yandex.Mail, Mail.ru, Gmail, SendGrid, any SMTP
# Example for Yandex:
#   Host: smtp.yandex.ru, Port: 465, SSL: true
#   User: noreply@podryad.pro, Password: app-password
