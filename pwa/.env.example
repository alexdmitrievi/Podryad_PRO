# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Session / Auth ──
SESSION_SECRET=generate-random-64-char-string
CUSTOMER_JWT_SECRET=generate-random-64-char-string

# ── Admin PIN ──
ADMIN_PIN=your_admin_pin

# ── App URL ──
NEXT_PUBLIC_APP_URL=https://podryad.pro

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Webhook secret — validates incoming Telegram updates
# Generate with: openssl rand -hex 32
# Set in BotFather: /setwebhook → https://podryad.pro/api/telegram/webhook → secret_token
TELEGRAM_WEBHOOK_SECRET=generate-random-32-char-string
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
NEXT_PUBLIC_MAX_CHANNEL_LINK=https://max.ru/podryad_pro

# ── Cron webhook security ──
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-random-32-char-string

# ── Upstash Redis (distributed rate limiter) ──
# Without these, the app falls back to in-memory rate limiting
# (per-instance only — not suitable for multi-instance Vercel deployments).
# Create a free database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── OpenAI GPT-4o (LLM for CRM Agent) ──
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_TIMEOUT=30000

# ── Channel Transport ──
# Telegram (already above in TELEGRAM_BOT_TOKEN)
# MAX Messenger
MAX_BOT_TOKEN=your_max_bot_access_token
# Webhook secret — validates incoming MAX updates
# Generate with: openssl rand -hex 32
MAX_WEBHOOK_SECRET=generate-random-32-char-string
# MAX channel ID for crossposting paid orders to a public MAX channel
MAX_CHANNEL_ID=
# Avito Messenger — uses single API token (not OAuth client_id/secret)
AVITO_API_TOKEN=your_avito_api_token
# Webhook secret — validates incoming Avito updates
# Generate with: openssl rand -hex 32
AVITO_WEBHOOK_SECRET=generate-random-32-char-string
# CRM: shared secret for /api/crm/update-stage
CRM_WEBHOOK_SECRET=generate-random-32-char-string

# ── Company details (for document generation: invoices, acts, UPD) ──
COMPANY_NAME=ИП Подряд ПРО
COMPANY_INN=your_inn
COMPANY_ADDRESS=your_legal_address
COMPANY_BANK=your_bank_name
COMPANY_BIK=your_bik
COMPANY_ACCOUNT=your_account_number
COMPANY_CORR_ACCOUNT=your_corr_account

# ── Payment gateway (optional — falls back to manual SBP flow) ──
# Set PAYMENT_GATEWAY to 'tinkoff' or 'yookassa' to enable online payments.
# Leave blank to keep the current manual SBP/bank-transfer flow.
PAYMENT_GATEWAY=
# Shared secret for /api/payment/create (admin/front-end → backend)
PAYMENT_API_SECRET=generate-random-32-char-string
# Tinkoff Kassa
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
# Admin notification for dead jobs — used by /api/health alert threshold
MAX_ADMIN_USER_ID=

# ── Push Notifications (Web Push / VAPID) ──
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@podryad.pro
