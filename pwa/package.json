{
  "name": "podryad-pro",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "dotenv -e .env.test.local -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test.local -- playwright test --ui",
    "test:e2e:api": "dotenv -e .env.test.local -- playwright test --project=API",
    "smoke": "npx tsx scripts/smoke-test.ts",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/supabase-js": "^2.99.3",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "^15.1.0",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
