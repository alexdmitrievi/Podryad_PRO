# Подряд PRO — Staging Environment
# Used for: CI previews, PR testing, staging deploy
#
# ⚠️ REAL SECRETS MUST NEVER BE IN THIS FILE
# Set secrets via Vercel Dashboard → Environment Variables
#
# ── Supabase (TEST project) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_supabase_service_role_key

# ── Auth / Session ──
SESSION_SECRET=generate-random-64-char-string
CUSTOMER_JWT_SECRET=generate-random-64-char-string
ADMIN_PIN=0000

# ── App URL ──
NEXT_PUBLIC_APP_URL=https://staging.podryad.pro
NEXT_PUBLIC_SITE_URL=https://staging.podryad.pro

# ── Cron ──
CRON_SECRET=generate-random-32-char-string

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=generate-random-32-char-string
NEXT_PUBLIC_BOT_NAME=Podryad_PRO_bot
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ── MAX ──
MAX_BOT_TOKEN=your_max_bot_token
MAX_WEBHOOK_SECRET=generate-random-32-char-string
MAX_CHANNEL_ID=your_max_channel_id
NEXT_PUBLIC_MAX_CHANNEL_LINK=https://max.ru/your_channel

# ── OpenAI ──
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

# ── Payment (manual) ──
PAYMENT_API_SECRET=generate-random-32-char-string
PAYMENT_GATEWAY=

# ── CRM ──
CRM_WEBHOOK_SECRET=generate-random-32-char-string

# ── Push / VAPID ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@podryad.pro
PUSH_API_SECRET=generate-random-32-char-string

# ── n8n webhooks ──
N8N_WEBHOOK_BASE=http://your-server:5678/webhook
N8N_LEADS_WEBHOOK_URL=http://your-server:5678/webhook/lead-notification

# ── E2E ──
E2E_ALLOW_PROD=0
