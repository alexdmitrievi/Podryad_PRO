            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ rental_id: $json.rental_id, equipment_id: $json.equipment_id, equipment_name: $json.equipment_name, renter_id: $json.user_id, renter_name: $json.first_name, duration: $json.duration_label, duration_hours: $json.duration_hours, price: $json.price, deposit: $json.deposit, status: 'pending', created_at: $json.created_at, paid_at: null, returned_at: null, yukassa_id: null }) }}",
        "options": {
          "timeout": 20000
        }
      },
      "id": "rent-save-018",
      "name": "Save Rental",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1460,
        600
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $('Calculate Rental Price').first().json;\n\nconst shopId = $env.YUKASSA_SHOP_ID;\nconst secretKey = $env.YUKASSA_SECRET_KEY;\nconst idempotenceKey = r.rental_id;\n\nconst payload = {\n  amount: {\n    value: String(r.price) + '.00',\n    currency: 'RUB'\n  },\n  confirmation: {\n    type: 'redirect',\n    return_url: 'https://podryad.pro/equipment'\n  },\n  capture: true,\n  description: `Аренда: ${r.equipment_name} (${r.duration_label})`,\n  metadata: {\n    rental_id: r.rental_id,\n    equipment_id: r.equipment_id,\n    type: 'rental'\n  }\n};\n\nreturn [{\n  json: {\n    url: 'https://api.yookassa.ru/v3/payments',\n    auth: Buffer.from(`${shopId}:${secretKey}`).toString('base64'),\n    idempotence_key: idempotenceKey,\n    payload,\n    rental: r\n  }\n}];"
      },
      "id": "rent-build-payment-019",
      "name": "Build YooKassa Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1700,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.yookassa.ru/v3/payments",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Basic {{ $json.auth }}"
            },
            {
              "name": "Idempotence-Key",
              "value": "={{ $json.idempotence_key }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.payload) }}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "rent-yukassa-020",
      "name": "YooKassa Create Payment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1940,
        600
      ]
    },
    {
      "parameters": {
        "jsCode": "const payment = $('YooKassa Create Payment').first().json;\nconst rental = $('Build YooKassa Request').first().json.rental;\nconst confirmUrl = payment.confirmation?.confirmation_url || '';\n\nlet text = `🔧 *Бронирование техники*\\n\\n`;\ntext += `📦 ${rental.equipment_name}\\n`;\ntext += `⏱ ${rental.duration_label}\\n`;\ntext += `💰 К оплате: *${rental.price}₽*\\n`;\ntext += `🔒 Залог при получении: ${rental.deposit}₽\\n\\n`;\ntext += `💳 Оплатите по ссылке:`;\n\nconst keyboard = JSON.stringify({\n  inline_keyboard: [\n    [{ text: `💳 Оплатить ${rental.price}₽`, url: confirmUrl }],\n    [{ text: '❌ Отменить', callback_data: `cancel_rent_${rental.rental_id}` }]\n  ]\n});\n\nreturn [{ json: { chat_id: rental.chat_id, text, keyboard } }];"
      },
      "id": "rent-build-pay-msg-021",
      "name": "Build Payment Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2180,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage' }}",
