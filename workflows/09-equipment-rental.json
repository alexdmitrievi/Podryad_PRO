      "id": "rent-callback-012",
      "name": "Callback Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        700
      ],
      "webhookId": "podryad-rent-callback",
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const cb = $input.first().json.callback_query;\nconst data = cb.data;\nconst chatId = cb.message.chat.id;\nconst userId = String(cb.from.id);\nconst firstName = cb.from.first_name || '';\nconst callbackId = cb.id;\n\n// rent_4h_mower-1, rent_day_mower-1, rent_3d_mower-1\nif (data.startsWith('rent_')) {\n  const parts = data.split('_');\n  // rent_4h_mower-1 → ['rent', '4h', 'mower-1']\n  // rent_3d_mower-1 → ['rent', '3d', 'mower-1']\n  // rent_catalog → ['rent', 'catalog']\n  \n  if (parts[1] === 'catalog') {\n    return [{ json: { action: 'catalog', chat_id: chatId, user_id: userId, callback_id: callbackId } }];\n  }\n  \n  const duration = parts[1]; // 4h, day, 3d\n  const equipId = parts.slice(2).join('_'); // mower-1\n  \n  return [{ json: { action: 'confirm_booking', duration, equipment_id: equipId, chat_id: chatId, user_id: userId, first_name: firstName, callback_id: callbackId } }];\n}\n\nreturn [];"
      },
      "id": "rent-parse-callback-013",
      "name": "Parse Rent Callback",
