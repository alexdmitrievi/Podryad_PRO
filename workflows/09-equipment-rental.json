    {
      "parameters": {
        "chatId": "={{ $('Parse Command').item.json.chat_id }}",
        "text": "❌ К сожалению, *{{ $json.name }}* сейчас в аренде.\n\nПопробуйте позже или выберите другую технику: /rent",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "rent-not-available-009",
      "name": "Not Available",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1220,
        500
      ],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const equip = $('Normalize Equipment Row').first().json;\nconst cmd = $('Parse Command').first().json;\n\nlet text = `🔧 *${equip.name}*\\n\\n`;\ntext += `${equip.description}\\n`;\ntext += `📐 ${equip.specs}\\n\\n`;\ntext += `*Тарифы:*\\n`;\ntext += `⏱ 4 часа: *${equip.rate_4h}₽*\\n`;\ntext += `📅 Сутки: *${equip.rate_day}₽*\\n`;\ntext += `📦 3 суток: *${equip.rate_3days}₽* (выгодно!)\\n\\n`;\ntext += `🔒 Залог: ${equip.deposit}₽ (возвращается при сдаче)\\n`;\ntext += `🚚 Доставка: 500₽ по городу / самовывоз бесплатно\\n\\n`;\ntext += `🎁 _Скидка 15% при заказе вместе с исполнителями_\\n\\n`;\ntext += `Выберите срок аренды:`;\n\nconst keyboard = {\n  inline_keyboard: [\n    [\n      { text: `4 часа — ${equip.rate_4h}₽`, callback_data: `rent_4h_${equip.equipment_id}` },\n      { text: `Сутки — ${equip.rate_day}₽`, callback_data: `rent_day_${equip.equipment_id}` }\n    ],\n    [\n      { text: `3 суток — ${equip.rate_3days}₽`, callback_data: `rent_3d_${equip.equipment_id}` }\n    ],\n    [\n      { text: '« Назад к каталогу', callback_data: 'rent_catalog' }\n    ]\n  ]\n};\n\nreturn [{ json: { chat_id: cmd.chat_id, text, keyboard: JSON.stringify(keyboard), equipment_id: equip.equipment_id } }];"
      },
      "id": "rent-build-detail-010",
      "name": "Build Detail Message",
      "type": "n8n-nodes-base.code",
