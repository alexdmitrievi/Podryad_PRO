      "id": "rent-lookup-for-book-015",
      "name": "Lookup For Booking",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        740,
        650
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst rows = Array.isArray(raw) ? raw : [raw];\nif (!rows[0]?.equipment_id) throw new Error('EQUIPMENT_NOT_FOUND');\nreturn [{ json: rows[0] }];"
      },
      "id": "norm-eq-book-09",
      "name": "Normalize Equipment Booking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        650
      ]
    },
    {
      "parameters": {
        "jsCode": "const equip = $('Normalize Equipment Booking').first().json;\nconst cmd = $('Parse Rent Callback').first().json;\n\nif (equip.status !== 'available') {\n  return [{ json: { ...cmd, error: true, message: 'Техника уже занята' } }];\n}\n\nconst durationMap = {\n  '4h': { label: '4 часа', rate_field: 'rate_4h', hours: 4 },\n  'day': { label: 'Сутки (24 часа)', rate_field: 'rate_day', hours: 24 },\n  '3d': { label: '3 суток', rate_field: 'rate_3days', hours: 72 }\n};\n\nconst dur = durationMap[cmd.duration] || durationMap['day'];\nconst price = parseInt(equip[dur.rate_field], 10) || 0;\nconst deposit = parseInt(equip.deposit, 10) || 0;\nconst totalToPay = price; // Залог берётся отдельно при получении\n\nconst rentalId = `R${Date.now().toString(36).toUpperCase()}`;\nconst createdAt = new Date().toISOString();\n\nreturn [{\n  json: {\n    rental_id: rentalId,\n    equipment_id: equip.equipment_id,\n    equipment_name: equip.name,\n    user_id: cmd.user_id,\n    first_name: cmd.first_name,\n    chat_id: cmd.chat_id,\n    callback_id: cmd.callback_id,\n    duration: cmd.duration,\n    duration_label: dur.label,\n    duration_hours: dur.hours,\n    price,\n    deposit,\n    total_to_pay: totalToPay,\n    status: 'pending',\n    created_at: createdAt,\n    error: false\n  }\n}];"
      },
      "id": "rent-calc-price-016",
      "name": "Calculate Rental Price",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        650
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "no-error",
              "leftValue": "={{ $json.error }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "rent-no-error-017",
      "name": "No Error?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1220,
        650
