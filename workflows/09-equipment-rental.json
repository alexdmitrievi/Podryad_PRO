        "url": "={{ $env.SUPABASE_URL.replace(/\\/$/, '') + '/rest/v1/equipment?select=*&equipment_id=eq.' + encodeURIComponent($json.equipment_id)' }}",
        "sendHeaders": true,
        "headerParameters": {
