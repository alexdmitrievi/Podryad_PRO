{
  "name": "Подряд PRO — 09 Equipment Rental",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "id": "rent-trigger-001",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        300
      ],
      "webhookId": "podryad-rent-trigger",
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst text = (msg.text || '').trim();\nconst chatId = msg.chat.id;\nconst userId = String(msg.from.id);\nconst username = msg.from.username || '';\nconst firstName = msg.from.first_name || '';\n\n// /start rent_mower-1 → deeplink из PWA\nif (text.startsWith('/start rent_')) {\n  const equipId = text.replace('/start rent_', '').trim();\n  return [{ json: { action: 'book', equipment_id: equipId, chat_id: chatId, user_id: userId, username, first_name: firstName } }];\n}\n\n// /rent → показать каталог\nif (text === '/rent' || text === '/rent@Podryad_PRO_bot') {\n  return [{ json: { action: 'catalog', chat_id: chatId, user_id: userId, username, first_name: firstName } }];\n}\n\n// /rent mower-1 → конкретная единица\nif (text.startsWith('/rent ')) {\n  const equipId = text.replace('/rent ', '').trim();\n  return [{ json: { action: 'book', equipment_id: equipId, chat_id: chatId, user_id: userId, username, first_name: firstName } }];\n}\n\n// /my_rentals → мои бронирования\nif (text === '/my_rentals') {\n  return [{ json: { action: 'my_rentals', chat_id: chatId, user_id: userId } }];\n}\n\n// Не наша команда — пропускаем\nreturn [];"
      },
      "id": "rent-parse-002",
      "name": "Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-catalog",
              "leftValue": "={{ $json.action }}",
              "rightValue": "catalog",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "is-book",
              "leftValue": "={{ $json.action }}",
              "rightValue": "book",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "is-my-rentals",
              "leftValue": "={{ $json.action }}",
              "rightValue": "my_rentals",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        },
        "fallbackOutput": "extra"
      },
      "id": "rent-switch-003",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
