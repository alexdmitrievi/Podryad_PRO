    {
      "parameters": {
        "jsCode": "const order = $('Sheets: Lookup Order').first().json;\n\nif (order.status !== 'published') {\n  throw new Error('ORDER_ALREADY_TAKEN');\n}\n\nconst callbackData = $('Parse Callback Data').first().json;\nconst worker = $('Check Worker Access').first().json.worker;\n\nreturn [{\n  json: {\n    order_id: order.order_id,\n    customer_id: order.customer_id,\n    address: order.address,\n    lat: order.lat,\n    lon: order.lon,\n    yandex_link: order.yandex_link,\n    time: order.time,\n    payment: order.payment,\n    people: order.people,\n    hours: order.hours,\n    work_type: order.work_type,\n    comment: order.comment,\n    message_id: order.message_id,\n    status: 'closed',\n    executor_id: callbackData.user_id,\n    executor_name: worker.name || callbackData.first_name,\n    executor_username: worker.username || callbackData.username,\n    executor_phone: worker.phone || 'не указан',\n    executor_rating: worker.rating || '5.00'\n  }\n}];"
      },
