    {
      "parameters": {
        "jsCode": "const o = $('Atomic Lock Check').first().json;\n\nconst timeText = o.time || 'По договорённости';\nconst paymentText = o.payment || 'По договорённости';\n\nconst executorMsg = `🎉 Заказ #${o.order_id} — ВАШ!\\n\\n📍 ${o.address}\\n🗺 ${o.yandex_link}\\n⏰ ${timeText}\\n💰 ${paymentText}\\n👥 ${o.people} чел. × ${o.hours} ч.\\n📋 ${o.work_type}${o.comment ? '\\n💬 ' + o.comment : ''}\\n\\n📞 Контакт заказчика: напишите ему в Telegram\\n\\n✅ По завершении нажмите: /done_${o.order_id}`;\n\nconst customerMsg = `✅ Исполнитель найден для заказа #${o.order_id}!\\n\\n👤 ${o.executor_name}${o.executor_username ? ' (@' + o.executor_username + ')' : ''}\\n⭐ Рейтинг: ${o.executor_rating}\\n📞 ${o.executor_phone}\\n\\nОн уже готов к работе!\\nПосле выполнения оцените работу: /done_${o.order_id}`;\n\nconst channelMsg = `🧾 РАБОТА ОМСК | Подряд PRO #${o.order_id}\\n\\n🔒 ЗАКРЫТ — исполнитель найден\\n\\n📍 ${o.address}\\n⏰ ${timeText}\\n💰 ${paymentText}\\n\\n#работаомск #омск`;\n\nreturn [{\n  json: {\n    executor_id: o.executor_id,\n    customer_id: o.customer_id,\n    executor_msg: executorMsg,\n    customer_msg: customerMsg,\n    channel_msg: channelMsg,\n    message_id: o.message_id\n  }\n}];"
      },
