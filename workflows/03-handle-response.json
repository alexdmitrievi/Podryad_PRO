      "id": "telegram-callback",
      "name": "Telegram Callback",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [220, 300],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const callback = $('Telegram Callback').first().json;\nconst data = callback.callback_query.data;\nconst userId = callback.callback_query.from.id;\nconst username = callback.callback_query.from.username || '';\nconst firstName = callback.callback_query.from.first_name || '';\nconst callbackId = callback.callback_query.id;\n\nlet action = '';\nlet orderId = '';\n\nif (data.startsWith('ready_')) {\n  action = 'ready';\n  orderId = data.replace('ready_', '');\n} else if (data.startsWith('go_')) {\n  action = 'go';\n  orderId = data.replace('go_', '');\n} else if (data.startsWith('book_')) {\n  action = 'book';\n  orderId = data.replace('book_', '');\n} else if (data.startsWith('pay_')) {\n  action = 'pay';\n  orderId = data.replace('pay_', '');\n} else if (data.startsWith('cancel_')) {\n  action = 'cancel';\n  orderId = data.replace('cancel_', '');\n} else {\n  action = 'unknown';\n  orderId = data;\n}\n\nreturn [{\n  json: {\n    action,\n    order_id: parseInt(orderId),\n    user_id: String(userId),\n    username,\n    first_name: firstName,\n    callback_id: callbackId\n  }\n}];"
      },
      "id": "parse-callback",
      "name": "Parse Callback Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "ready_or_go",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "ready",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              }
            },
            {
              "outputKey": "ready_or_go",
              "conditions": {
                "conditions": [
