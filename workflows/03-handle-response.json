      "id": "sheets-lookup-worker",
      "name": "Sheets: Lookup Worker",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1320, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const workers = $('Sheets: Lookup Worker').all();\nconst callbackData = $('Parse Callback Data').first().json;\n\nif (workers.length === 0) {\n  return [{\n    json: {\n      access: false,\n      reason: 'not_registered',\n      message: '⛔ Вы не зарегистрированы как исполнитель.\\n\\nНапишите @Podryad_PRO_bot чтобы зарегистрироваться.'\n    }\n  }];\n}\n\nconst worker = workers[0].json;\n\nif (worker.white_list !== 'TRUE' && worker.white_list !== true) {\n  return [{\n    json: {\n      access: false,\n      reason: 'not_whitelisted',\n      message: '⛔ У вас нет доступа к заказам.\\n\\nОбратитесь к администратору: @Podryad_PRO_bot'\n    }\n  }];\n}\n\nconst rating = parseFloat(worker.rating) || 5.0;\nif (rating < 4.0) {\n  return [{\n    json: {\n      access: false,\n      reason: 'low_rating',\n      message: `⛔ Ваш рейтинг (${rating}) ниже минимального (4.0).\\n\\nВыполняйте заказы качественно для повышения рейтинга.`\n    }\n  }];\n}\n\nif (worker.ban_until) {\n  const banDate = new Date(worker.ban_until);\n  if (banDate > new Date()) {\n    const banStr = banDate.toLocaleDateString('ru-RU');\n    return [{\n      json: {\n        access: false,\n        reason: 'banned',\n        message: `⛔ Вы заблокированы до ${banStr}.\\n\\nОбратитесь к администратору: @Podryad_PRO_bot`\n      }\n    }];\n  }\n}\n\nreturn [{\n  json: {\n    access: true,\n    worker: worker\n  }\n}];"
      },
