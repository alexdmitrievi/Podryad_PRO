{
  "name": "Подряд PRO — 18 Customer Lead Nurture Agent (RAG)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "crm-lead-nurture",
        "options": {
          "responseMode": "onReceived"
        }
      },
      "id": "rag-wh-001",
      "name": "Webhook: New Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ],
      "webhookId": "podryad-crm-lead-nurture"
    },
    {
      "parameters": {
        "jsCode": "const root = $('Webhook: New Lead').first().json;\nconst b = root.body || root;\n\nconst phone = String(b.phone || '').replace(/\\D/g, '');\nconst name = String(b.name || '').trim();\nconst workType = String(b.work_type || 'labor');\nconst city = String(b.city || 'omsk');\nconst messenger = String(b.messenger || 'max').toLowerCase();\nconst email = String(b.email || '').trim();\nconst telegram = String(b.telegram || '').trim();\nconst comment = String(b.comment || '').trim();\nconst leadId = b.lead_id ? Number(b.lead_id) : null;\n\nconst WORK_TYPE_LABELS = {\n  labor: 'разнорабочих / строительные работы',\n  equipment: 'технику / спецтехнику',\n  materials: 'строительные материалы',\n  complex: 'комплексные работы'\n};\nconst CITY_LABELS = { novosibirsk: 'Новосибирске', omsk: 'Омске' };\n\nconst workLabel = WORK_TYPE_LABELS[workType] || workType;\nconst cityLabel = CITY_LABELS[city] || city;\n\nreturn [{ json: {\n  phone, name, workType, workLabel, city, cityLabel,\n  messenger, email, telegram, comment, leadId,\n hasTelegram: !!telegram\n} }];"
      },
      "id": "rag-parse-002",
      "name": "Parse Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ]
    },
