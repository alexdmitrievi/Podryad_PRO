    {
      "parameters": {
        "jsCode": "// ── RAG Welcome Message Generator ──\nconst lead = $('Parse Lead Data').first().json;\nconst funnelRaw = $('Upsert CRM Funnel').first().json;\nconst funnel = Array.isArray(funnelRaw) ? funnelRaw[0] : funnelRaw;\nconst historyRaw = $('RAG: Fetch History').first().json;\nconst history = Array.isArray(historyRaw) ? historyRaw : [];\n\nconst name = lead.name || '';\nconst nameGreeting = name ? name.split(' ')[0] + ', здравствуйте!' : 'Здравствуйте!';\nconst workLabel = lead.workLabel;\nconst cityLabel = lead.cityLabel;\n\n// ── RAG: Build conversation context ──\nlet ragContext = '';\nlet lastUserMsg = '';\nlet interactionCount = history.length;\n\nif (history.length > 0) {\n  const recent = history.slice().reverse().slice(-10);\n  for (const msg of recent) {\n    const dir = msg.direction === 'inbound' ? '← Клиент' : '→ Мы';\n    ragContext += `${dir}: ${msg.message_text.slice(0, 200)}\\n`;\n    if (msg.direction === 'inbound') lastUserMsg = msg.message_text;\n  }\n}\n\nconst prevSummary = (funnel && funnel.conversation_summary) || '';\n\n// ── Generate contextual welcome ──\nlet welcomeMsg;\nif (interactionCount > 0 && lastUserMsg) {\n  welcomeMsg = `${nameGreeting} 👋\\n\\nВижу, что мы с вами уже общались — вы интересовались ${workLabel} в ${cityLabel}.`;\n  if (lastUserMsg.length > 10) {\n    welcomeMsg += ` В прошлый раз вы писали: «${lastUserMsg.slice(0, 80)}...»`;\n  }\n  welcomeMsg += `\\n\\nХотели бы продолжить? Готов помочь с оформлением заказа — обычно подбираем бригаду за 2–4 часа! 🏗`;\n} else {\n  welcomeMsg = `${nameGreeting} 👋\\n\\nЯ получил вашу заявку на ${workLabel} в ${cityLabel}.\\n\\nМы — сервис Подряд PRO, помогаем быстро найти проверенных исполнителей. Обычно подбираем бригаду за 2–4 часа.\\n\\n⏱ Уточните, пожалуйста:\\n• Когда планируете начать работы?\\n• Примерный объём / площадь?\\n\\nОтвечу по деталям и рассчитаю стоимость 🏗`;\n}\n\n\nconst summaryUpdate = interactionCount > 0\n  ? `Повторный контакт (${interactionCount} сообщ. в истории). Отправлено приветствие с учётом предыдущего общения.`\n  : `Первый контакт. Заявка на ${workLabel} в ${cityLabel}.`;\n\nreturn [{ json: {\n  ...lead, welcomeMsg,\n  summaryUpdate, ragContext, interactionCount, lastUserMsg,\n  leadFunnelId: funnel ? funnel.id : null\n} }];"
      },
      "id": "rag-welcome-005",
      "name": "RAG: Generate Welcome",
      "type": "n8n-nodes-base.code",
