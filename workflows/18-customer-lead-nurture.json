      "parameters": {
        "jsCode": "const tokens = $input.first().json;\nconst phone = $('Parse Lead + Build Messages').first().json.phone;\nconst followup1 = $('Parse Lead + Build Messages').first().json.followup1Msg;\nlet dashboardLink = `https://app.podryad.pro/dashboard?phone=${phone}`;\nif (Array.isArray(tokens) && tokens.length > 0 && tokens[0].access_token) {\n  dashboardLink = `https://app.podryad.pro/my?token=${tokens[0].access_token}`;\n}\nconst msg = followup1 + `\\n\\n🔗 Ваш личный кабинет: ${dashboardLink}`;\nreturn [{ json: { msg, dashboardLink, phone } }];"
      },
