    {
      "parameters": {
        "jsCode": "// ── RAG Follow-up 1 Message Generator ──\nconst lead = $('Parse Lead Data').first().json;\nconst historyRaw = $('RAG: Fetch History (2)').first().json;\nconst history = Array.isArray(historyRaw) ? historyRaw : [];\nconst tokens = $('Get Customer Token').first().json;\n\nconst name = lead.name || '';\nconst firstName = name ? name.split(' ')[0] : '';\nconst workLabel = lead.workLabel;\nconst cityLabel = lead.cityLabel;\nconst phone = lead.phone;\n\n// ── RAG context ──\nlet lastUserMsg = '';\nlet hasInbound = false;\nfor (const m of history) {\n  if (m.direction === 'inbound') { lastUserMsg = m.message_text; hasInbound = true; }\n}\n\n// Dashboard link\nlet dashboardLink = `https://app.podryad.pro/dashboard?phone=${phone}`;\nif (Array.isArray(tokens) && tokens.length > 0 && tokens[0].access_token) {\n  dashboardLink = `https://app.podryad.pro/my?token=${tokens[0].access_token}`;\n}\n\n// Generate contextual follow-up 1\nlet msg;\nif (hasInbound && lastUserMsg) {\n  msg = `${firstName ? firstName + ', д' : 'Д'}обрый день! Спасибо за ваш ответ 🙏\\n\\nОтвечая на ваше сообщение: «${lastUserMsg.slice(0, 80)}»\\n\\nМы уже подбираем специалистов по ${workLabel} в ${cityLabel}. Вот ваш личный кабинет для удобного оформления:\\n\\n🔗 ${dashboardLink}\\n\\nТам можно описать задачу подробнее — и мы подберём лучших мастеров!`;\n} else {\n  msg = `${firstName ? firstName + ', в' : 'В'}ы оставили заявку на ${workLabel} в ${cityLabel}. Мы уже подбираем специалистов под ваш запрос! 💪\\n\\nВот ваш личный кабинет — здесь можно оформить заказ за 5 минут:\\n\\n🔗 ${dashboardLink}\\n\\nГотов рассказать подробнее и помочь с оформлением 📞`;\n}\n\n  ? 'Подряд PRO — мы уже подбираем мастеров'\n  : `Подряд PRO — ваш личный кабинет`;\n\n\nconst summaryUpdate = hasInbound\n  ? `Follow-up 1: клиент ответил (\"${lastUserMsg.slice(0, 60)}\"). Отправлена ссылка на ЛК.`\n  : `Follow-up 1: нет ответа. Отправлена ссылка на ЛК.`;\n\nreturn [{ json: {\n  ...lead, msg, dashboardLink,\n  summaryUpdate, hasInbound, lastUserMsg\n} }];"
      },
