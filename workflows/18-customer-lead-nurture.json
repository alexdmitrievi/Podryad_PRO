        "jsCode": "// ── RAG Follow-up 2 Message Generator ──\nconst lead = $('Parse Lead Data').first().json;\nconst historyRaw = $('RAG: Fetch History (3)').first().json;\nconst history = Array.isArray(historyRaw) ? historyRaw : [];\n\nconst name = lead.name || '';\nconst firstName = name ? name.split(' ')[0] : '';\nconst workLabel = lead.workLabel;\nconst cityLabel = lead.cityLabel;\n\n// ── RAG: Analyze conversation ──\nlet lastUserMsg = '';\nlet userMsgCount = 0;\nlet ourMsgCount = 0;\nfor (const m of history) {\n  if (m.direction === 'inbound') { lastUserMsg = m.message_text; userMsgCount++; }\n  else ourMsgCount++;\n}\n\n// ── Generate contextual follow-up 2 ──\nlet msg;\nif (userMsgCount > 0 && lastUserMsg) {\n  msg = `${firstName ? firstName + ', з' : 'З'}дравствуйте! Хотел вернуться к нашему разговору 🤝\\n\\n`;\n  if (lastUserMsg.length > 10) {\n    msg += `Вы упоминали: «${lastUserMsg.slice(0, 80)}»\\n\\n`;\n  }\n  msg += `Мы можем помочь с ${workLabel} прямо сейчас — есть свободные бригады в ${cityLabel}. Оформление заказа займёт всего 5 минут!\\n\\nНапишите, если остались вопросы — отвечу лично 💬`;\n} else {\n  msg = `Добрый день! Хочу убедиться, что вы нашли то, что искали.\\n\\nЕсли ещё нужна помощь с ${workLabel} в ${cityLabel} — мы готовы помочь. Прямо сейчас есть свободные бригады!\\n\\nЗа 5 минут оформим заказ и найдём проверенного мастера. Напишите «Да» — и я всё организую 👷`;\n}\n\n\nconst summaryUpdate = `Follow-up 2: ${userMsgCount > 0 ? 'клиент ответил ' + userMsgCount + ' раз' : 'нет ответа'}. Всего отправлено ${ourMsgCount} сообщений.`;\n\nreturn [{ json: {\n  ...lead, msg,\n  summaryUpdate, userMsgCount\n} }];"
      },
