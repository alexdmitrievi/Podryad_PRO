    {
      "parameters": {
        "jsCode": "// ── RAG Final Message Generator ──\nconst lead = $('Parse Lead Data').first().json;\nconst historyRaw = $('RAG: Fetch History (4)').first().json;\nconst history = Array.isArray(historyRaw) ? historyRaw : [];\n\nconst name = lead.name || '';\nconst firstName = name ? name.split(' ')[0] : '';\nconst workLabel = lead.workLabel;\nconst cityLabel = lead.cityLabel;\nconst city = lead.city;\n\n// ── RAG: Full conversation analysis ──\nlet totalOutbound = 0;\nlet totalInbound = 0;\nlet lastUserMsg = '';\nconst channels = new Set();\nfor (const m of history) {\n  channels.add(m.channel);\n  if (m.direction === 'inbound') { totalInbound++; lastUserMsg = m.message_text; }\n  else totalOutbound++;\n}\n\nconst cityName = city === 'novosibirsk' ? 'Новосибирску' : 'Омску';\n\n// ── Generate contextual final message ──\nlet msg;\nif (totalInbound > 0) {\n  msg = `${firstName ? firstName + ', д' : 'Д'}обрый день! Мы общались по поводу ${workLabel} — хотел узнать, актуален ли ещё вопрос?\\n\\nЕсли да — готов помочь оформить заказ прямо сейчас 💪\\nЕсли уже решили — рад, что помогли! Сохраните мой контакт на будущее 🙂\\n\\nРаботаем по всему ${cityName}!`;\n} else {\n  msg = `Здравствуйте! Последний раз пишу по вашей заявке на ${workLabel} 🙂\\n\\nЕсли вопрос ещё актуален — напишите, и мы оформим заказ за 5 минут.\\nЕсли уже решили — всё в порядке! Сохраните контакт на будущее.\\n\\nРаботаем по всему ${cityName}. Всегда на связи! 🤝`;\n}\n\n\nconst summaryUpdate = `Final: ${totalInbound > 0 ? 'клиент отвечал ' + totalInbound + ' раз' : 'нет ответа за весь цикл'}. Всего ${totalOutbound} исх. сообщений через ${[...channels].join(', ')}. Лид → cold.`;\n\nreturn [{ json: {\n  ...lead, msg,\n  summaryUpdate, totalInbound, totalOutbound\n} }];"
      },
