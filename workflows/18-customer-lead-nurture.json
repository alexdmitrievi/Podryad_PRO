{
  "name": "Подряд PRO — 18 Customer Lead Nurture Agent",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "crm-lead-nurture",
        "options": { "responseMode": "onReceived" }
      },
      "id": "clna-wh-001",
      "name": "Webhook: New Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "podryad-crm-lead-nurture"
    },
    {
      "parameters": {
        "jsCode": "const root = $('Webhook: New Lead').first().json;\nconst b = root.body || root;\n\nconst phone = String(b.phone || '').replace(/\\D/g, '');\nconst name = String(b.name || '').trim();\nconst workType = String(b.work_type || 'labor');\nconst city = String(b.city || 'omsk');\nconst messenger = String(b.messenger || 'max').toLowerCase();\nconst email = String(b.email || '').trim();\nconst telegram = String(b.telegram || '').trim();\nconst comment = String(b.comment || '').trim();\nconst leadId = b.lead_id ? Number(b.lead_id) : null;\n\nconst WORK_TYPE_LABELS = {\n  labor: 'разнорабочих / строительные работы',\n  equipment: 'технику / спецтехнику',\n  materials: 'строительные материалы',\n  complex: 'комплексные работы'\n};\n\nconst workLabel = WORK_TYPE_LABELS[workType] || workType;\nconst cityLabel = city === 'novosibirsk' ? 'Новосибирске' : 'Омске';\nconst nameGreeting = name ? `${name.split(' ')[0]}, привет!` : 'Привет!';\n\n// Приветственное сообщение для заказчика\nconst welcomeMsg = `${nameGreeting} 👋\\n\\nЯ получил вашу заявку на ${workLabel} в ${cityLabel}.\\n\\nМы — сервис Подряд PRO, помогаем быстро найти проверенных исполнителей. Обычно подбираем бригаду за 2–4 часа.\\n\\n⏱ Уточните, пожалуйста:\\n• Когда планируете начать работы?\\n• Примерный объём / площадь?\\n\\nОтвечу по деталям и рассчитаю стоимость 🏗`;\n\n// Follow-up через 2 часа (если не ответил)\nconst followup1Msg = `${name ? name.split(' ')[0] + ', вы' : 'Вы'} оставили заявку на ${workLabel} в ${cityLabel}. Мы уже подбираем специалистов под ваш запрос!\\n\\nГотов рассказать подробнее и прислать ссылку для оформления заказа — когда вам удобно поговорить? 📞`;\n\n// Follow-up через 24 часа\nconst followup2Msg = `Добрый день! Хочу убедиться, что вы нашли то, что искали. Если ещё нужна помощь с ${workLabel} — мы готовы помочь.\\n\\nЗа 5 минут оформим заказ и найдём проверенного мастера. Вот ваша персональная ссылка: [ссылка] 👇`;\n\n// Финальный follow-up через 3 дня\nconst followup3Msg = `Последний раз пишу — если заявка была разовой или уже решили вопрос, всё в порядке 🙂\\n\\nЕсли вдруг в будущем снова понадобятся мастера или техника — сохраните мой контакт! Работаем по всему ${city === 'novosibirsk' ? 'Новосибирску' : 'Омску'}.`;\n\nreturn [{\n  json: {\n    phone, name, workType, city, cityLabel, workLabel,\n    messenger, email, telegram, comment, leadId,\n    welcomeMsg, followup1Msg, followup2Msg, followup3Msg,\n    hasEmail: !!email,\n    hasTelegram: !!telegram,\n    preferMax: messenger === 'max' || !messenger || messenger === 'по умолчанию',\n    preferTg: messenger === 'telegram' || messenger === 'tg',\n    preferEmail: messenger === 'email',\n  }\n}];"
      },
      "id": "clna-parse-002",
      "name": "Parse Lead + Build Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
