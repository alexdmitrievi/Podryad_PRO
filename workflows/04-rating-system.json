        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Workers"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "telegram_id": "={{ $json.telegram_id }}",
            "rating": "={{ $json.rating }}",
            "jobs_count": "={{ $json.jobs_count }}",
            "balance": "={{ $json.balance }}",
            "ban_until": "={{ $json.ban_until }}",
            "consecutive_low": "={{ $json.consecutive_low }}"
          }
        },
        "options": { "cellFormat": "USER_ENTERED" }
      },
      "id": "sheets-update-worker",
