    },
    {
      "parameters": {
        "updates": ["callback_query"],
        "additionalFields": {}
      },
      "id": "telegram-rating-callback",
      "name": "Rating Callback",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [220, 700],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.callback_query.data }}",
              "rightValue": "rate_",
              "operator": { "type": "string", "operation": "startsWith" }
            }
          ]
        }
      },
      "id": "if-rating-callback",
      "name": "Is Rating Callback?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [440, 700]
    },
    {
      "parameters": {
        "jsCode": "const data = $('Rating Callback').first().json.callback_query.data;\nconst callbackId = $('Rating Callback').first().json.callback_query.id;\n\nconst parts = data.replace('rate_', '').split('_');\nconst score = parseInt(parts[0]);\nconst orderId = parseInt(parts[1]);\n\nreturn [{\n  json: {\n    score,\n    order_id: orderId,\n    callback_id: callbackId\n  }\n}];"
      },
      "id": "parse-rating",
      "name": "Parse Rating",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 700]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.GOOGLE_SHEETS_ID }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Orders"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "order_id",
              "lookupValue": "={{ $json.order_id }}"
            }
          ]
        },
        "options": {}
      },
      "id": "sheets-lookup-order-rating",
      "name": "Sheets: Order for Rating",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [880, 700],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
