    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.GOOGLE_SHEETS_ID }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Workers"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "telegram_id",
              "lookupValue": "={{ $json.executor_id }}"
            }
          ]
        },
        "options": {}
      },
      "id": "sheets-lookup-worker-rating",
      "name": "Sheets: Worker for Rating",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1100, 700],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const worker = $('Sheets: Worker for Rating').first().json;\nconst newScore = $('Parse Rating').first().json.score;\nconst orderId = $('Parse Rating').first().json.order_id;\n\nconst oldRating = parseFloat(worker.rating) || 5.0;\nconst count = parseInt(worker.jobs_count) || 0;\n\nconst newRating = ((oldRating * count) + newScore) / (count + 1);\nconst roundedRating = Math.round(newRating * 100) / 100;\n\nlet needsBanCheck = false;\nlet penalty = 'none';\nlet banUntil = worker.ban_until || '';\nlet balance = parseInt(worker.balance) || 0;\n\nif (newScore <= 2) {\n  needsBanCheck = true;\n  \n  const consecutiveLow = parseInt(worker.consecutive_low || '0') + 1;\n  \n  if (consecutiveLow >= 3) {\n    const banDate = new Date();\n    banDate.setDate(banDate.getDate() + 30);\n    banUntil = banDate.toISOString();\n    penalty = 'ban_30_days';\n  } else if (consecutiveLow >= 2) {\n    balance -= 500;\n    penalty = 'fine_500';\n  } else {\n    penalty = 'warning';\n  }\n  \n  return [{\n    json: {\n      telegram_id: worker.telegram_id,\n      rating: roundedRating,\n      jobs_count: count + 1,\n      balance: balance,\n      ban_until: banUntil,\n      consecutive_low: consecutiveLow,\n      penalty: penalty,\n      score: newScore,\n      order_id: orderId,\n      needs_ban_check: true\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    telegram_id: worker.telegram_id,\n    rating: roundedRating,\n    jobs_count: count + 1,\n    balance: balance,\n    ban_until: banUntil,\n    consecutive_low: 0,\n    penalty: 'none',\n    score: newScore,\n    order_id: orderId,\n    needs_ban_check: false\n  }\n}];"
      },
      "id": "calc-rating",
      "name": "Calculate New Rating",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 700]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.GOOGLE_SHEETS_ID }}"
