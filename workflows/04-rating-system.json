        "jsCode": "const data = $('Calculate New Rating').first().json;\nconst stars = '⭐'.repeat(data.score);\n\nconst text = `✅ Спасибо за оценку!\\n\\nЗаказ #${data.order_id}\\nОценка: ${stars} (${data.score}/5)\\n\\nВаш отзыв помогает улучшить качество сервиса!`;\n\nconst customerId = $('Sheets: Order for Rating').first().json.customer_id;\n\nreturn [{\n  json: {\n    chat_id: customerId,\n    text: text\n  }\n}];"
      },
