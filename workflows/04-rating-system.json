{
  "name": "04 — Rating System",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [220, 300],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.message.text }}",
              "rightValue": "/done_",
              "operator": { "type": "string", "operation": "startsWith" }
            }
          ]
        }
      },
      "id": "if-done-command",
      "name": "Is /done Command?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "jsCode": "const text = $('Telegram Trigger').first().json.message.text;\nconst userId = String($('Telegram Trigger').first().json.message.from.id);\nconst orderId = text.replace('/done_', '').trim();\n\nreturn [{\n  json: {\n    order_id: parseInt(orderId),\n    caller_id: userId\n  }\n}];"
      },
      "id": "parse-done",
      "name": "Parse /done Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.GOOGLE_SHEETS_ID }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "Orders"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "order_id",
              "lookupValue": "={{ $json.order_id }}"
            }
          ]
        },
        "options": {}
      },
      "id": "sheets-lookup-order",
      "name": "Sheets: Lookup Order",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [880, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.status }}",
              "rightValue": "closed",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "if-order-closed",
      "name": "Is Order Closed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $('Parse /done Command').first().json.caller_id }}",
        "text": "❌ Заказ #{{ $('Parse /done Command').first().json.order_id }} не найден или не в статусе \"закрыт\".\n\nУбедитесь, что номер заказа правильный.",
        "additionalFields": {}
      },
      "id": "send-not-found",
      "name": "Send: Not Found",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1320, 160],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const order = $('Sheets: Lookup Order').first().json;\nconst callerId = $('Parse /done Command').first().json.caller_id;\n\nconst isCustomer = String(order.customer_id) === callerId;\nconst isExecutor = String(order.executor_id) === callerId;\n\nif (!isCustomer && !isExecutor) {\n  return [{\n    json: {\n      role: 'unknown',\n      order_id: order.order_id\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    role: isCustomer ? 'customer' : 'executor',\n    order_id: order.order_id,\n    customer_id: order.customer_id,\n    executor_id: order.executor_id,\n    caller_id: callerId\n  }\n}];"
      },
      "id": "determine-role",
      "name": "Determine Caller Role",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 380]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "customer",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.role }}",
                    "rightValue": "customer",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              }
            },
            {
              "outputKey": "executor",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.role }}",
                    "rightValue": "executor",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              }
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "id": "switch-role",
      "name": "Switch Role",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1540, 380]
    },
    {
      "parameters": {
        "chatId": "={{ $json.customer_id }}",
        "text": "❓ Как прошёл заказ #{{ $json.order_id }}?\nОцените исполнителя от 1 до 5:\n\n1 — Плохо\n2 — Ниже среднего\n3 — Нормально\n4 — Хорошо\n5 — Отлично\n\nОтправьте цифру (1-5):",
        "additionalFields": {
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"⭐ 1\",\"callback_data\":\"rate_1_{{ $json.order_id }}\"},{\"text\":\"⭐⭐ 2\",\"callback_data\":\"rate_2_{{ $json.order_id }}\"},{\"text\":\"⭐⭐⭐ 3\",\"callback_data\":\"rate_3_{{ $json.order_id }}\"}],[{\"text\":\"⭐⭐⭐⭐ 4\",\"callback_data\":\"rate_4_{{ $json.order_id }}\"},{\"text\":\"⭐⭐⭐⭐⭐ 5\",\"callback_data\":\"rate_5_{{ $json.order_id }}\"}]]}"
        }
      },
      "id": "send-rating-request",
      "name": "Send Rating Request",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1760, 300],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $json.caller_id }}",
        "text": "✅ Спасибо! Мы отправили заказчику запрос на оценку вашей работы по заказу #{{ $json.order_id }}.\n\nХорошая оценка повышает ваш рейтинг и даёт доступ к лучшим заказам!",
        "additionalFields": {}
      },
      "id": "send-executor-done",
      "name": "Notify Executor: Done Received",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1760, 500],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
