{
  "name": "Подряд PRO — 02 Publish Order",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "payment-callback",
        "options": {
          "responseMode": "onReceived",
          "responseData": "allEntries"
        }
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000001",
      "name": "Webhook Payment",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        200
      ],
      "webhookId": "podryad-payment-cb"
    },
    {
      "parameters": {
        "updates": [
          "callback_query"
        ],
        "additionalFields": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000002",
      "name": "Telegram Admin Approve",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        500
      ],
      "webhookId": "podryad-admin-approve",
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Определяем источник: webhook ЮKassa или Telegram admin\nconst webhookData = $('Webhook Payment').first()?.json;\nconst tgData = $('Telegram Admin Approve').first()?.json;\n\nlet orderId, source;\n\nif (webhookData?.object?.metadata?.order_id) {\n  // ЮKassa webhook\n  orderId = webhookData.object.metadata.order_id;\n  source = 'yukassa';\n} else if (tgData?.callback_query?.data) {\n  // Admin approve: approve_123\n  const data = tgData.callback_query.data;\n  if (data.startsWith('approve_')) {\n    orderId = data.replace('approve_', '');\n    source = 'admin';\n  }\n}\n\nif (!orderId) {\n  throw new Error('NO_ORDER_ID: не удалось определить order_id');\n}\n\nreturn [{ json: { order_id: orderId, source } }];"
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000003",
      "name": "Extract Order ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        350
      ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "https://docs.google.com/spreadsheets/d/1gEHLSNMQIIxieDdHjrvgE15_AkoJleuWKLRajZIOCk/edit?usp=sharing",
          "mode": "url"
        },
        "sheetName": {
          "__rl": true,
          "value": "Orders",
          "mode": "list"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "order_id",
              "lookupValue": "={{ $json.order_id }}"
            }
          ]
        },
        "options": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000004",
      "name": "Lookup Order",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        520,
        350
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-pending",
              "leftValue": "={{ $json.status }}",
              "rightValue": "pending",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000005",
      "name": "Is Pending?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        760,
        350
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendLocation",
        "chatId": "-1003710991577",
        "latitude": "={{ $json.lat }}",
        "longitude": "={{ $json.lon }}",
        "additionalFields": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000006",
      "name": "Send Location",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1020,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const order = $('Lookup Order').first().json;\n\nconst workTypeHashtag = {\n  'грузчики': '#грузчикиомск',\n  'уборка': '#уборкаомск',\n  'стройка': '#стройкаомск',\n  'другое': '#подработкаомск'\n};\n\nconst hashtag = workTypeHashtag[order.work_type] || '#подработкаомск';\n\nlet text = `🧾 РАБОТА ОМСК | Подряд PRO #${order.order_id}\\n\\n`;\ntext += `📍 ${order.address}\\n`;\ntext += `🗺 <a href=\"${order.yandex_link}\">Открыть на карте</a>\\n\\n`;\n\nif (order.time) text += `⏰ ${order.time}\\n`;\nif (order.payment) text += `💰 ${order.payment}\\n`;\nif (order.people) text += `👥 ${order.people} чел.`;\nif (order.hours) text += ` × ${order.hours} ч.`;\ntext += `\\n📋 ${order.work_type}\\n`;\nif (order.comment) text += `💬 ${order.comment}\\n`;\n\ntext += `\\n👇 Нажми кнопку чтобы взять заказ!\\n@Podryad_PRO_bot\\n\\n`;\ntext += `#работаомск #подработка ${hashtag} #омск`;\n\nconst keyboard = JSON.stringify({\n  inline_keyboard: [\n    [\n      { text: 'Готов 👍', callback_data: `ready_${order.order_id}` },\n      { text: 'Еду 🚚', callback_data: `go_${order.order_id}` }\n    ],\n    [\n      { text: '🔒 Забронировать за 1000р', callback_data: `book_${order.order_id}` }\n    ]\n  ]\n});\n\nreturn [{ json: { text, keyboard, order_id: order.order_id } }];"
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000007",
      "name": "Build Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1260,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "-1003710991577",
        "text": "={{ $json.text }}",
        "additionalFields": {
          "parse_mode": "HTML",
          "replyMarkup": "inlineKeyboard",
          "inlineKeyboard": {
            "rows": [
              {
                "row": {
                  "buttons": [
                    {
                      "text": "Готов 👍",
                      "additionalFields": {
                        "callbackData": "ready_{{ $json.order_id }}"
                      }
                    },
                    {
                      "text": "Еду 🚚",
                      "additionalFields": {
                        "callbackData": "go_{{ $json.order_id }}"
                      }
                    }
                  ]
                }
              },
              {
                "row": {
                  "buttons": [
                    {
                      "text": "🔒 Забронировать за 1000р",
                      "additionalFields": {
                        "callbackData": "book_{{ $json.order_id }}"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000008",
      "name": "Publish to Channel",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1500,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "https://docs.google.com/spreadsheets/d/1gEHLSNMQIIxieDdHjrvgE15_AkoJleuWKLRajZIOCk/edit?usp=sharing",
          "mode": "url"
        },
        "sheetName": {
          "__rl": true,
          "value": "Orders",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "order_id": "={{ $('Build Post').item.json.order_id }}",
            "status": "published",
            "message_id": "={{ $('Publish to Channel').item.json.message_id }}"
          },
          "matchingColumns": [
            "order_id"
          ]
        },
        "options": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000009",
      "name": "Update Order Status",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1740,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "https://docs.google.com/spreadsheets/d/1gEHLSNMQIIxieDdHjrvgE15_AkoJleuWKLRajZIOCk/edit?usp=sharing",
          "mode": "url"
        },
        "sheetName": {
          "__rl": true,
          "value": "Payments",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "order_id": "={{ $('Extract Order ID').item.json.order_id }}",
            "status": "paid",
            "paid_at": "={{ new Date().toISOString() }}"
          },
          "matchingColumns": [
            "order_id"
          ]
        },
        "options": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000010",
      "name": "Update Payment",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1740,
        500
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "3",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $('Lookup Order').item.json.customer_id }}",
        "text": "✅ Оплата получена! Ваш заказ #{{ $('Build Post').item.json.order_id }} опубликован в канале.\n\n📢 Ожидайте отклика исполнителей — мы уведомим вас!",
        "additionalFields": {}
      },
      "id": "b1b2c3d4-2222-4000-8000-000000000011",
      "name": "Notify Customer",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1980,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {},
