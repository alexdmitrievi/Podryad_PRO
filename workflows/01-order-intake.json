        [{ "node": "Send Welcome", "type": "main", "index": 0 }],
        [{ "node": "Send Order Help", "type": "main", "index": 0 }],
        [],
        [{ "node": "OpenAI Parse Order", "type": "main", "index": 0 }]
      ]
    },
    "OpenAI Parse Order": {
