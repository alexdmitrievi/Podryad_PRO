    {
      "parameters": {
        "jsCode": "let raw = $('OpenAI Parse').first().json.message.content || '';\nraw = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  throw new Error('INVALID_OPENAI_JSON: ' + raw);\n}\n\nconst allowed = ['грузчики', 'уборка', 'стройка', 'разнорабочие', 'другое'];\nif (!allowed.includes(parsed.work_type)) parsed.work_type = 'другое';\n\nreturn [{ json: parsed }];"
      },
