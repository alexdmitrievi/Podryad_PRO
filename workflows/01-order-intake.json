    {
      "parameters": {
        "jsCode": "const order = $('Read Saved Order').first()?.json || $('Build Order Object').first().json;\nconst orderId = order.order_id || 'new';\n\nconst text =\n`✅ *Заказ принят!*\\n\\n` +\n`📍 ${order.address}\\n` +\n`🗺 [Открыть на карте](${order.yandex_link})\\n` +\n`⏰ ${order.time || 'не указано'}\\n` +\n`👥 ${order.people} чел. × ${order.hours} ч.\\n` +\n`📋 ${order.work_type}\\n\\n` +\n`━━━━━━━━━━━━━━━━━━\\n` +\n`💰 *Стоимость: ${order.client_total}₽*\\n` +\n`  (${order.client_rate}₽/час × ${order.people} чел × ${order.hours} ч)\\n` +\n`━━━━━━━━━━━━━━━━━━\\n\\n` +\n`💳 Оплатите для публикации заказа:`;\n\nreturn [{\n  json: {\n    order_id: String(orderId),\n    client_total: Number(order.client_total),\n    text\n  }\n}];"
      },
      "id": "a1b2c3d4-1111-4000-8000-000000000021",
      "name": "Build Customer Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2570,
        1100
      ]
    },
    {
      "parameters": {
        "jsCode": "const order = $('Build Customer Message').first().json;\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\nconst shopId = $env.YUKASSA_SHOP_ID;\nconst secretKey = $env.YUKASSA_SECRET_KEY;\n\nif (!shopId || !secretKey) {\n  throw new Error('YUKASSA_SHOP_ID / YUKASSA_SECRET_KEY not set in n8n Variables');\n}\n\nconst auth = Buffer.from(shopId + ':' + secretKey).toString('base64');\nconst idempotenceKey = 'order_' + order.order_id + '_' + Date.now();\n\nconst body = {\n  amount: {\n    value: String(Number(order.client_total).toFixed(2)),\n    currency: 'RUB'\n  },\n  confirmation: {\n    type: 'redirect',\n    return_url: 'https://podryadpro.ru/app/payments'\n  },\n  capture: true,\n  description: 'Подряд PRO — Заказ #' + order.order_id,\n  metadata: {\n    order_id: String(order.order_id)\n  }\n};\n\nreturn [{\n  json: {\n    auth_header: 'Basic ' + auth,\n    idempotence_key: idempotenceKey,\n    request_body: JSON.stringify(body),\n    order_id: order.order_id,\n    client_total: order.client_total,\n    text: order.text,\n    chat_id: String(chatId)\n  }\n}];"
      },
