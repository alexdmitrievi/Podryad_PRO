    {
      "parameters": {
        "jsCode": "const allWorkers = $('Normalize All Workers').all().map(i => i.json);\nconst description = $('Parse /pick Request').first().json.description;\n\nconst eligible = allWorkers\n  .filter(w => {\n    const whitelisted = w.white_list === 'TRUE' || w.white_list === true;\n    const highRating = parseFloat(w.rating || '0') >= 4.5;\n    const notBanned = !w.ban_until || new Date(w.ban_until) < new Date();\n    return whitelisted && highRating && notBanned;\n  })\n  .sort((a, b) => {\n    const ratingDiff = parseFloat(b.rating || '0') - parseFloat(a.rating || '0');\n    if (ratingDiff !== 0) return ratingDiff;\n    return parseInt(b.jobs_count || '0') - parseInt(a.jobs_count || '0');\n  })\n  .slice(0, 3);\n\nif (eligible.length === 0) {\n  return [{\n    json: {\n      has_workers: false,\n      description: description\n    }\n  }];\n}\n\nconst workersData = eligible.map(w => ({\n  name: w.name,\n  rating: w.rating,\n  jobs_count: w.jobs_count,\n  skills: w.skills,\n  is_vip: w.is_vip\n}));\n\nreturn [{\n  json: {\n    has_workers: true,\n    workers_array: JSON.stringify(workersData),\n    description: description,\n    top_workers: eligible\n  }\n}];"
      },
