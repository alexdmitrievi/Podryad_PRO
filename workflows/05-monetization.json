      "parameters": {
        "jsCode": "const yukassa = $('YooKassa VIP Payment').first().json;\nconst paymentUrl = yukassa.confirmation?.confirmation_url;\nconst userId = $('Build VIP Payment').first().json.user_id;\n\nif (!paymentUrl) {\n  throw new Error('No VIP payment URL from YooKassa');\n}\n\nconst text = '🌟 VIP-подписка — 1000₽/мес\\n\\nПреимущества:\\n• Ранний доступ к заказам (на 30 мин раньше)\\n• Приоритет при отклике\\n• Значок VIP в профиле\\n• Поддержка 24/7\\n\\n💳 Нажмите кнопку для оплаты:';\n\nconst keyboard = JSON.stringify({\n  inline_keyboard: [\n    [{ text: '💳 Оплатить VIP — 1000₽', url: paymentUrl }]\n  ]\n});\n\nreturn [{\n  json: {\n    chat_id: userId,\n    text: text,\n    reply_markup: keyboard\n  }\n}];"
      },
