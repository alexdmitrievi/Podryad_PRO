        "jsCode": "const yukassa = $('YooKassa Pick Payment').first().json;\nconst paymentUrl = yukassa.confirmation?.confirmation_url;\nconst pickData = $('Build Pick Payment').first().json;\n\nif (!paymentUrl) {\n  throw new Error('No Pick payment URL from YooKassa');\n}\n\nconst text = '🏆 Подбор исполнителей — Подряд PRO\\n\\n' + pickData.recommendation + '\\n\\n💳 Для получения контактов оплатите 1000₽.\\nПосле оплаты мы отправим вам номера телефонов.';\n\nconst keyboard = JSON.stringify({\n  inline_keyboard: [\n    [{ text: '💳 Получить контакты — 1000₽', url: paymentUrl }]\n  ]\n});\n\nreturn [{\n  json: {\n    chat_id: pickData.user_id,\n    text: text,\n    reply_markup: keyboard\n  }\n}];"
      },
