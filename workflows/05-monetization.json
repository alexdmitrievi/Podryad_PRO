    {
      "parameters": {
        "jsCode": "const workers = $('Normalize VIP Worker').all();\nconst userId = String($('Telegram Trigger').first().json.message.from.id);\n\nif (workers.length === 0) {\n  return [{\n    json: {\n      is_vip: false,\n      is_registered: false,\n      user_id: userId\n    }\n  }];\n}\n\nconst worker = workers[0].json;\nconst isVip = worker.is_vip === 'TRUE' || worker.is_vip === true;\nlet vipActive = false;\n\nif (isVip && worker.vip_expires_at) {\n  vipActive = new Date(worker.vip_expires_at) > new Date();\n}\n\nreturn [{\n  json: {\n    is_vip: vipActive,\n    is_registered: true,\n    vip_expires_at: worker.vip_expires_at || '',\n    user_id: userId,\n    worker_name: worker.name || ''\n  }\n}];"
      },
