    {
      "parameters": {
        "jsCode": "const userId = $('Check VIP Status').first().json.user_id;\nconst shopId = $env.YUKASSA_SHOP_ID;\nconst secretKey = $env.YUKASSA_SECRET_KEY;\n\nif (!shopId || !secretKey) {\n  throw new Error('YUKASSA credentials not configured in n8n Variables');\n}\n\nconst auth = Buffer.from(shopId + ':' + secretKey).toString('base64');\nconst idempotenceKey = 'vip_' + userId + '_' + Date.now();\n\nconst body = {\n  amount: { value: '1000.00', currency: 'RUB' },\n  confirmation: { type: 'redirect', return_url: 'https://podryadpro.ru/app/payments' },\n  capture: true,\n  description: 'Подряд PRO — VIP подписка',\n  metadata: { user_id: String(userId), type: 'vip' }\n};\n\nreturn [{\n  json: {\n    auth_header: 'Basic ' + auth,\n    idempotence_key: idempotenceKey,\n    request_body: JSON.stringify(body),\n    user_id: userId\n  }\n}];"
      },
